{
  "prefix": "<gray>[</gray><gold>RankSystem</gold><gray>]</gray>",
  "sorry": "${prefix} <red>Entschuldigung!</red>",
  "invalid-rank": "${sorry} Aber dieser Rang existiert nicht!",

  "command.ranks.desc": "Dieser Befehl erlaubt es Server-Admins Ränge zu verwalten.",
  "command.ranks.register.failure.already": "${sorry} Aber dieser Rang existiert bereits!",
  "command.ranks.register.success": "${prefix} '$0' <green>wurde erfolgreich registriert</green>!",

  "command.ranks.unregister.failure.already": "${sorry} Aber dieser Rang existiert nicht!",
  "command.ranks.unregister.success": "${prefix} '$0' <green>wurde erfolgreich gelöscht</green>!",

  "command.ranks.list.msg.empty": "${sorry} Aber es gibt aktuell noch keine Ränge!",
  "command.ranks.list.l1": "${prefix} Aktuell sind die folgenden Ränge registriert <gray>($0)</gray>:",
  "command.ranks.list.l2": "<gray>-</gray> $0 <gray>(Position: $1; $2 Spieler)</gray>",

  "command.ranks.player.list.msg.empty": "${sorry} Aber der Spieler <gray>$0</gray> besitzt keinen Rang!",
  "command.ranks.player.list.l1": "${prefix} <gray>$0</gray> hat die folgenden Ränge <gray>($1)</gray>:",
  "command.ranks.player.list.l2": "<gray>-</gray> $0 <gray>(Position: $1; $2 Spieler)</gray>",

  "command.ranks.player.add.failure.invalid_rank": "${invalid-rank}",
  "command.ranks.player.add.failure.already": "${sorry} Aber dieser Spieler besitzt bereits den Rang '<gray>$0</gray>'!",
  "command.ranks.player.add.success": "${prefix} <green><white>$0</white> wurde erfolgreich zu <white>'$1'</white> hinzugefügt!</green>",

  "command.ranks.player.remove.failure.invalid_rank": "${invalid-rank}",
  "command.ranks.player.remove.failure.not": "${sorry} Aber dieser Spieler besitzt den Rang '<gray>$0</gray>' nicht!",
  "command.ranks.player.remove.success": "${prefix} <green>Der Rang <white>$0</white> wurde erfolgreich von <white>'$1'</white> entfernt!</green>",

  "command.ranks.permission.add.success": "${prefix} <green>Permission wurde erfolgreich zu <white>'$0'</white> hinzugefügt!</green>",
  "command.ranks.permission.add.failure.invalid_rank": "${invalid-rank}",

  "command.ranks.permission.remove.success": "${prefix} <green>Permission wurde erfolgreich von <white>'$0'</white> entfernt!</green>",
  "command.ranks.permission.remove.failure.invalid_rank": "${invalid-rank}",

  "command.ranks.permission.list.failure.invalid_rank": "${invalid-rank}",
  "command.ranks.permission.list.msg.empty": "${sorry} Aber es gibt keine Permissions für diesen Rang!",
  "command.ranks.permission.list.l1": "${prefix} Es gibt die folgenden Permissions <gray>($0)</gray>:",
  "command.ranks.permission.list.l2": "<gray>-</gray> $0",

  "command.ranks.position.get.failure.invalid_rank": "${invalid-rank}",
  "command.ranks.position.get.msg": "${prefix} Position des Rangs <gray>$0</gray>: $1",

  "command.ranks.position.set.failure.invalid_rank": "${invalid-rank}",
  "command.ranks.position.set.success": "${prefix} <green>Position wurde erfolgreich geändert:</green> '$0'!",

  "command.ranks.prefix.get.failure.invalid_rank": "${invalid-rank}",
  "command.ranks.prefix.get.failure.blank": "${sorry} Aber dieser Rang besitzt keinen Prefix!",
  "command.ranks.prefix.get.msg": "${prefix} Prefix von '$0': $1",
  "command.ranks.prefix.set.failure.invalid_rank": "${invalid-rank}",
  "command.ranks.prefix.set.success": "${prefix} <green>Prefix wurde erfolgreich geändert für</green> '$0'!",
  "command.ranks.prefix.remove.failure.invalid_rank": "${invalid-rank}",
  "command.ranks.prefix.remove.success": "${prefix} <green>Prefix wurde erfolgreich entfernt von</green> '$0'!",

  "command.ranks.suffix.get.failure.invalid_rank": "${invalid-rank}",
  "command.ranks.suffix.get.failure.blank": "${sorry} Aber dieser Rang hat keinen Prefix!",
  "command.ranks.suffix.get.msg": "${prefix} Suffix von '$0': $1",
  "command.ranks.suffix.set.failure.invalid_rank": "${invalid-rank}",
  "command.ranks.suffix.set.success": "${prefix} <green>Suffix wurde erfolgreich geändert für</green> '$0'!",
  "command.ranks.suffix.remove.failure.invalid_rank": "${invalid-rank}",
  "command.ranks.suffix.remove.success": "${prefix} <green>Suffix wurde erfolgreich entfernt von</green> '$0'!",

  "command.ranks.default.get.failure.none": "${sorry} Aber es gibt keinen standard Rang",
  "command.ranks.default.get.msg": "${prefix} <gray>Der standard Rang ist aktuell</gray> '$0'",
  "command.ranks.default.set.failure.invalid_rank": "${invalid-rank}",
  "command.ranks.default.set.success": "${prefix} <green>Standard Rang wurde erfolgreich auf <white>'$0'</white> gesetzt!</green>",

  "command.ranks.language.failure.invalid": "${sorry} Aber die Sprache <gray>'$0'</gray> wird nicht unterstützt!",
  "command.ranks.language.success": "${prefix} <green>Sprach-Präferenz wurde erfolgreich auf <white>$0</white> gesetzt!</green>"
}